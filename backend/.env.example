# PostgreSQL + pgvector. Do not commit the real .env file.
DATABASE_URL=postgresql://ai_app:replace-with-your-db-password@127.0.0.1:5432/ai_platform
AUTH_SECRET_KEY=replace-with-a-long-random-secret

# LLM 配置（支持 OpenAI 兼容接口：DeepSeek / 通义千问 / 智谱 GLM 等）
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TEMPERATURE=0.7
